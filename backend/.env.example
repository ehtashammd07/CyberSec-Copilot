# CyberSec Copilot — Backend Environment (Phi Edition)

# Ollama - Microsoft Phi model (fast, lightweight ~1.6GB)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=phi              # options: phi, phi3, phi3.5, phi3-mini

OLLAMA_TIMEOUT=60             # phi is fast, 60s is plenty

# Embedding model (downloaded automatically on first run)
EMBEDDING_MODEL=all-MiniLM-L6-v2
VECTOR_DIM=384

# Paths (relative to backend/ folder)
VECTOR_STORE_PATH=../vector_store/faiss_index
DOCUMENTS_PATH=../vector_store/documents.json
DATASET_PATH=../dataset/cybersec_kb.json
TOP_K_RESULTS=5

# App
DEBUG=true
ALLOWED_ORIGINS=["http://localhost:3000","http://127.0.0.1:3000"]
